<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- Telegram Bot Configuration -->
    <add key="Telegram:BotToken" value="YOUR_BOT_TOKEN_HERE" />
    <add key="Telegram:ChatId" value="YOUR_CHAT_ID_HERE" />
    <add key="Telegram:EncryptionKey" value="YourSecureEncryptionKey123!@#$%^" />
    
    <!-- Security Settings -->
    <add key="Security:EnableTokenEncryption" value="true" />
    <add key="Security:LogSensitiveData" value="false" />
  </appSettings>

  <!-- Connection Strings -->
  <connectionStrings>
    <!-- Add your database connection strings here if needed -->
  </connectionStrings>

  <!-- Startup -->
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
</configuration>